{
  "name": "@bemedev/tansolid-monorepo",
  "private": true,
  "description": "TanStack Router and Solid JS utilities monorepo",
  "keywords": [
    "solid-js",
    "tanstack",
    "router",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "chlbri",
    "email": "bri_lvi@icloud.com",
    "url": "https://bemedev.vercel.app"
  },
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/tansolid"
  },
  "workspaces": [
    "packages/tansolid",
    "packages/__tests__/project1"
  ],
  "type": "module",
  "scripts": {
    "pnpm:devPreinstall": "node -e \"const fs=require('fs'); const pkg=JSON.parse(fs.readFileSync('./package.json')); const version=require('child_process').execSync('pnpm -v').toString().trim(); pkg.packageManager='pnpm@' + version; fs.writeFileSync('./package.json', JSON.stringify(pkg, null, 2) + '\\n');\"",
    "build": "pnpm -r --sort run build",
    "config": "pnpm i",
    "rimraf": "pnpx rimraf -rf",
    "rinit": "pnpm run rm && pnpm run config",
    "lint": "pnpm run -r lint",
    "test": "pnpm run -r test",
    "pretest": "pnpm run -r pretest",
    "posttest": "pnpm run -r posttest",
    "test:only": "pnpm run -r test:only",
    "_ci": "pnpm install && pnpm run -r _ci",
    "ci": "CI=$(date +%s) && pnpm run _ci && echo \"\\n✅ CI takes $(($(date +%s) - CI))s\\n\"",
    "ci:admin": "CI_ADMIN=$(date +%s) && pnpm run _ci && echo \"\\n✅ Admin CI takes $(($(date +%s) - CI_ADMIN))s\\n\"",
    "rm": "pnpm clean lockfile",
    "up": "pnpm -r update --latest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@bemedev/better-promise": "^0.1.1",
    "@bemedev/better-set": "^0.2.1",
    "@bemedev/boolean-recursive": "^0.0.3",
    "@bemedev/decompose": "^2.2.0",
    "@bemedev/dev-utils": "^0.8.0",
    "@bemedev/interval2": "^1.0.1",
    "@bemedev/pipe": "^1.6.1",
    "@bemedev/rolldown-config": "^0.5.0",
    "@bemedev/rx-pausable": "^1.2.0",
    "@bemedev/scheduler": "^1.1.0",
    "@bemedev/sequence": "^1.0.0",
    "@bemedev/sleep": "^0.2.2",
    "@bemedev/typings": "^1.2.0",
    "@types/clone-deep": "^4.0.4",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "add": "^2.0.6",
    "clone-deep": "^4.0.1",
    "cmd-ts": "^0.15.0",
    "deepmerge-ts": "^7.1.5",
    "fast-deep-equal": "^3.1.3",
    "fast-glob": "^3.3.3",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "is-online": "^12.0.2",
    "nanoid": "^5.1.11",
    "node-watch": "^0.7.4",
    "onchange": "^7.1.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "rolldown": "1.1.0",
    "rxjs": "^7.8.2",
    "ts-morph": "^28.0.0",
    "tsc-alias": "^1.8.17",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "valibot": "^1.4.1",
    "vitest": "^4.1.8",
    "zx": "^8.8.5"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2"
}
