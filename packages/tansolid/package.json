{
  "name": "@bemedev/tansolid",
  "version": "0.2.0",
  "description": "TanStack Router and Solid JS utilities",
  "license": "MIT",
  "author": {
    "name": "chlbri",
    "email": "bri_lvi@icloud.com",
    "url": "https://bemedev.vercel.app"
  },
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/tansolid"
  },
  "files": [
    "lib",
    "public"
  ],
  "type": "module",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": "lib/scripts/cli/index.js",
  "imports": {
    "#codebase": "./.codebase.json"
  },
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.cjs",
      "types": "./lib/index.d.ts"
    },
    "./atoms": {
      "import": "./lib/ui/atoms/index.js",
      "require": "./lib/ui/atoms/index.cjs",
      "types": "./lib/ui/atoms/index.d.ts"
    },
    "./atoms/*": {
      "import": "./lib/ui/atoms/*.js",
      "require": "./lib/ui/atoms/*.cjs",
      "types": "./lib/ui/atoms/*.d.ts"
    },
    "./constants": {
      "import": "./lib/constants/index.js",
      "require": "./lib/constants/index.cjs",
      "types": "./lib/constants/index.d.ts"
    },
    "./directives": {
      "import": "./lib/ui/directives/index.js",
      "require": "./lib/ui/directives/index.cjs",
      "types": "./lib/ui/directives/index.d.ts"
    },
    "./directives/*": {
      "import": "./lib/ui/directives/*.js",
      "require": "./lib/ui/directives/*.cjs",
      "types": "./lib/ui/directives/*.d.ts"
    },
    "./molecules": {
      "import": "./lib/ui/molecules/index.js",
      "require": "./lib/ui/molecules/index.cjs",
      "types": "./lib/ui/molecules/index.d.ts"
    },
    "./molecules/*": {
      "import": "./lib/ui/molecules/*.js",
      "require": "./lib/ui/molecules/*.cjs",
      "types": "./lib/ui/molecules/*.d.ts"
    },
    "./organisms": {
      "import": "./lib/ui/organisms/index.js",
      "require": "./lib/ui/organisms/index.cjs",
      "types": "./lib/ui/organisms/index.d.ts"
    },
    "./organisms/*": {
      "import": "./lib/ui/organisms/*.js",
      "require": "./lib/ui/organisms/*.cjs",
      "types": "./lib/ui/organisms/*.d.ts"
    },
    "./signals": {
      "import": "./lib/ui/signals/index.js",
      "require": "./lib/ui/signals/index.cjs",
      "types": "./lib/ui/signals/index.d.ts"
    },
    "./signals/*": {
      "import": "./lib/ui/signals/*.js",
      "require": "./lib/ui/signals/*.cjs",
      "types": "./lib/ui/signals/*.d.ts"
    },
    "./types": {
      "import": "./lib/types/index.js",
      "require": "./lib/types/index.cjs",
      "types": "./lib/types/index.d.ts"
    },
    "./ui": {
      "import": "./lib/ui/index.js",
      "require": "./lib/ui/index.cjs",
      "types": "./lib/ui/index.d.ts"
    },
    "./utils": {
      "import": "./lib/utils/index.js",
      "require": "./lib/utils/index.cjs",
      "types": "./lib/utils/index.d.ts"
    },
    "./utils/*": {
      "import": "./lib/utils/*.js",
      "require": "./lib/utils/*.cjs",
      "types": "./lib/utils/*.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm run rm:lib && pnpm run codegen && pnpm run rolldown && chmod +x lib/scripts/cli/index.js",
    "codegen": "pnpm codebase -x \"./src/**/*.test-d.ts\" -x \"./src/scripts/**/*\"",
    "_ci": "pnpm run lint && pnpm run test",
    "ci": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && echo \"\\n✅ CI takes $(($(date +%s) - CI_START))s\\n\"",
    "ci:admin": "pnpm run rm && pnpm run upgrade && pnpm run ci",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "_lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:watch": "onchange --await-write-finish 5500 \"**/*\" -- pnpm run lint",
    "posttest": "pnpm run fmt",
    "prepublishOnly": "",
    "pretest": "pnpm run build",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rimraf": "pnpx rimraf -rf",
    "rm": "pnpm run rimraf -- node_modules pnpm-lock.yaml",
    "rm:lib": "pnpm run rimraf -- lib",
    "rolldown": "rolldown -c",
    "test": "pnpm run test:coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:coverage": "vitest run",
    "test:ui": "vitest ui",
    "test:watch": "vitest",
    "upgrade": "pnpm upgrade --latest"
  },
  "dependencies": {
    "@bemedev/codebase": "^1.2.2",
    "@bemedev/pipe": "^1.6.1",
    "clsx": "^2.1.1",
    "cmd-ts": "^0.15.0",
    "color": "^5.0.3",
    "edit-json-file": "^1.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "@kobalte/core": "^0.13.11",
    "@tanstack/solid-router": "1.170.15",
    "lucide-solid": "^1.21.0",
    "solid-js": "^1.9.13",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@bemedev/dev-utils": "^0.8.3",
    "@kobalte/core": "^0.13.11",
    "@rollup/plugin-json": "^6.1.0",
    "@tanstack/solid-router": "1.170.16",
    "@types/edit-json-file": "^1.7.4",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.1.3",
    "solid-js": "^1.9.13",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "valibot": "^1.4.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
